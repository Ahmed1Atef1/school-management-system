<?php
// conect.php.example - Database connection template
$host = "localhost";
$user = "your_db_username";
$pass = "your_db_password";
$db   = "your_db_name";

$conect = new mysqli($host, $user, $pass, $db);
if ($conect->connect_error) {
    die("Connection failed: " . $conect->connect_error);
}
$conect->set_charset("utf8mb4");
$conn = $conect;
?>